{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "custom-exam/judge_result.schema.json",
  "title": "JudgeResultArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "exam_id",
    "run_id",
    "question_id",
    "judge_version",
    "status",
    "hard_score",
    "soft_score",
    "total_score",
    "hard_checks",
    "soft_checks",
    "failure_tags",
    "judge_summary",
    "trace"
  ],
  "properties": {
    "exam_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "question_id": {
      "type": "string",
      "minLength": 1
    },
    "judge_version": {
      "type": "string",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "enum": [
        "success",
        "error"
      ]
    },
    "hard_score": {
      "type": "number",
      "minimum": 0
    },
    "soft_score": {
      "type": "number",
      "minimum": 0
    },
    "total_score": {
      "type": "number",
      "minimum": 0
    },
    "hard_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "passed",
          "score",
          "note"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "passed": {
            "type": "boolean"
          },
          "score": {
            "type": "number",
            "minimum": 0
          },
          "max_score": {
            "type": "number",
            "minimum": 0
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "soft_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "score",
          "max_score",
          "note"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "minimum": 0
          },
          "max_score": {
            "type": "number",
            "minimum": 0
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "failure_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "judge_summary": {
      "type": "string"
    },
    "report_markdown": {
      "type": "string"
    },
    "cap_applied": {
      "type": "boolean"
    },
    "trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adapter_version",
        "source_skill"
      ],
      "properties": {
        "adapter_version": {
          "type": "string",
          "minLength": 1
        },
        "source_skill": {
          "type": "string",
          "minLength": 1
        },
        "request_id": {
          "type": "string",
          "minLength": 1
        },
        "idempotency_key": {
          "type": "string",
          "minLength": 1
        },
        "bundle_hash": {
          "type": "string",
          "minLength": 1
        },
        "request_generated_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "request_started_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "request_completed_at": {
          "type": [
            "string",
            "null"
          ]
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "stage",
        "retryable",
        "message"
      ],
      "properties": {
        "code": {
          "type": "string",
          "minLength": 1
        },
        "stage": {
          "type": "string",
          "minLength": 1
        },
        "retryable": {
          "type": "boolean"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
