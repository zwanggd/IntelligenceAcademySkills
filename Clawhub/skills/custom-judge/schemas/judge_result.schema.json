{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "custom-exam/judge_result.schema.json",
  "title": "JudgeResultArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "exam_id",
    "run_id",
    "question_id",
    "hard_score",
    "soft_score",
    "total_score",
    "hard_checks",
    "soft_checks",
    "failure_tags",
    "judge_summary"
  ],
  "properties": {
    "exam_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "question_id": {
      "type": "string",
      "minLength": 1
    },
    "hard_score": {
      "type": "number",
      "minimum": 0
    },
    "soft_score": {
      "type": "number",
      "minimum": 0
    },
    "total_score": {
      "type": "number",
      "minimum": 0
    },
    "hard_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "passed",
          "score",
          "note"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "passed": {
            "type": "boolean"
          },
          "score": {
            "type": "number",
            "minimum": 0
          },
          "max_score": {
            "type": "number",
            "minimum": 0
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "soft_checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "score",
          "max_score",
          "note"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "score": {
            "type": "number",
            "minimum": 0
          },
          "max_score": {
            "type": "number",
            "minimum": 0
          },
          "note": {
            "type": "string"
          }
        }
      }
    },
    "failure_tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "judge_summary": {
      "type": "string"
    },
    "cap_applied": {
      "type": "boolean"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
