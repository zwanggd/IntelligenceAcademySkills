{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "custom-exam/exam_answer.schema.json",
  "title": "ExamAnswerArtifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "exam_id",
    "run_id",
    "question_id",
    "dimension",
    "answer_text",
    "artifacts",
    "trace",
    "metadata"
  ],
  "properties": {
    "exam_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "question_id": {
      "type": "string",
      "minLength": 1
    },
    "dimension": {
      "type": "string",
      "minLength": 1
    },
    "answer_text": {
      "type": "string"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "type",
          "path"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "type": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "description": {
            "type": "string"
          }
        }
      }
    },
    "trace": {
      "type": "object",
      "description": "Structured trace data for reproducibility. Keep lightweight.",
      "additionalProperties": true
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "created_at": {
          "type": "string"
        },
        "author": {
          "type": "string"
        },
        "exam_version": {
          "type": "string"
        }
      }
    }
  }
}
