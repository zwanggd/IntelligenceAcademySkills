{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "custom-judge/judge_input_manifest.schema.json",
  "title": "JudgeInputManifest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "manifest_version",
    "judge_version",
    "exam_id",
    "run_id",
    "question_id",
    "dimension",
    "source_answer_artifact",
    "weights",
    "expected_output_paths"
  ],
  "properties": {
    "manifest_version": {
      "type": "string",
      "minLength": 1
    },
    "judge_version": {
      "type": "string",
      "minLength": 1
    },
    "exam_id": {
      "type": "string",
      "minLength": 1
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "question_id": {
      "type": "string",
      "minLength": 1
    },
    "dimension": {
      "type": "string",
      "minLength": 1
    },
    "source_answer_artifact": {
      "type": "string",
      "minLength": 1
    },
    "bundle_root": {
      "type": "string"
    },
    "attachments_contract": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "mode": {
          "type": "string",
          "enum": [
            "attachments_only"
          ]
        },
        "sandbox": {
          "type": "string",
          "enum": [
            "require"
          ]
        }
      }
    },
    "weights": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "hard",
        "soft",
        "total"
      ],
      "properties": {
        "hard": {
          "type": "number",
          "minimum": 0
        },
        "soft": {
          "type": "number",
          "minimum": 0
        },
        "total": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "score_cap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "enabled"
      ],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "hard_below": {
          "type": "number",
          "minimum": 0
        },
        "total_cap": {
          "type": "number",
          "minimum": 0
        }
      }
    },
    "expected_output_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "judge_result_json",
        "judge_result_md"
      ],
      "properties": {
        "judge_result_json": {
          "type": "string",
          "minLength": 1
        },
        "judge_result_md": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
